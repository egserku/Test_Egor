rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: orders
    // Document ID: auto-generated (usually ORD-timestamp)
    // Fields:
    //   - uid: string (required) - The user ID of the customer (can be anonymous).
    //   - orderNumber: string (required) - The order number.
    //   - customer: map (required) - Customer contact info.
    //   - items: list (required) - List of OrderItem objects.
    //   - status: string (required) - The current status of the order.
    //   - createdAt: timestamp (required) - The time the order was created.
    //   - viewed: bool (required) - Whether the admin has viewed the order.
    //
    // Collection: schools
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required) - The name of the school.
    //   - logo: string (required) - The Base64 string of the school's logo.
    //
    // Collection: inventory
    // Document ID: auto-generated
    // Fields:
    //   - productType: string (required) - The type of product.
    //   - color: string (required) - The color of the product.
    //   - size: string (required) - The size of the product.
    //   - quantity: number (required) - The quantity in stock.
    //   - sleeve: string (optional) - The sleeve length.
    //   - fabric: string (optional) - The fabric type.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          request.auth.token.email == "egserku@gmail.com");
    }

    function isValidOrder(data) {
      return data.uid is string &&
             data.status in ['New', 'Processing', 'Completed', 'Cancelled'] &&
             data.createdAt is timestamp &&
             data.customer is map &&
             data.items is list;
    }

    function isValidSchool(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.logo is string && data.logo.size() > 0 && data.logo.size() < 1000000;
    }

    function isValidInventory(data) {
      return data.productType in ['TSHIRT', 'HOODIE', 'TANK_TOP', 'CAP'] &&
             data.color is string &&
             data.size is string &&
             data.quantity is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /orders/{orderId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && 
                      request.resource.data.uid == request.auth.uid &&
                      isValidOrder(request.resource.data);
      allow update: if (isDocOwner() && 
                        request.resource.data.uid == resource.data.uid &&
                        request.resource.data.createdAt == resource.data.createdAt &&
                        isValidOrder(request.resource.data)) || isAdmin();
      allow delete: if isAdmin();
    }

    match /schools/{schoolId} {
      allow read: if true; // Public list
      allow write: if isAdmin() && isValidSchool(request.resource.data);
    }

    match /inventory/{itemId} {
      allow read: if true; // Public list for stock info
      allow write: if isAdmin() && isValidInventory(request.resource.data);
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }
  }
}
